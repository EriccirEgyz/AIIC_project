# Copy this file to .env.local for development.
# Production: set these in your server's env (pm2 ecosystem file or systemd).

# ---------- Database ----------
# SQLite, lives at ./prisma/dev.db. In production point it at a writable path.
DATABASE_URL="file:./dev.db"

# ---------- LLM Provider ----------
# Pick ONE: openrouter | deepseek | qwen
# Default: openrouter. If your CN server cannot reach openrouter.ai,
# switch to deepseek or qwen — no code changes needed.
LLM_PROVIDER="openrouter"

# OpenRouter — get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# Optional: override default chat model (Claude Sonnet 4.6 is the recommended interviewer)
OPENROUTER_MAIN_MODEL="anthropic/claude-sonnet-4.6"
OPENROUTER_LITE_MODEL="anthropic/claude-haiku-4.5"

# DeepSeek fallback (CN-reachable, cheap) — https://platform.deepseek.com
DEEPSEEK_API_KEY=""
DEEPSEEK_MAIN_MODEL="deepseek-chat"

# Qwen / DashScope fallback (Alibaba Cloud native) — https://dashscope.aliyun.com
QWEN_API_KEY=""
QWEN_MAIN_MODEL="qwen-plus"

# Optional outbound proxy for whichever provider you use (e.g. CN server -> openrouter)
# Format: http://host:port  Leave empty to disable.
HTTPS_PROXY=""
