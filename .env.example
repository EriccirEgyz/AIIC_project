# Copy this file to .env.local for development.
# Production: set these in your server's env (pm2 ecosystem file or systemd).

# ---------- Database ----------
# SQLite, lives at ./dev.db in dev. In prod point at a writable path on the server.
DATABASE_URL="file:./dev.db"

# ---------- LLM Provider ----------
# Pick ONE: openrouter | deepseek | qwen
# Default: openrouter. Switch to deepseek/qwen if your OpenRouter key doesn't
# work for the models you need.
LLM_PROVIDER="openrouter"

# OpenRouter — get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# Recommended for Chinese 保研 use case:
#   qwen/qwen-plus-2025-07-28  - Alibaba native, $0.26/$0.78 per MTok, 1M ctx
# Alternatives that worked in testing:
#   deepseek/deepseek-v3.2     - $0.252/$0.378
#   mistralai/mistral-small-3.2-24b-instruct - $0.075/$0.20 (cheapest)
#   openai/gpt-4o-mini         - $0.15/$0.60 (requires OPENROUTER_PROVIDER_ORDER="Azure" from CN)
OPENROUTER_MAIN_MODEL="qwen/qwen-plus-2025-07-28"
OPENROUTER_LITE_MODEL="qwen/qwen-plus-2025-07-28"

# Force a specific OpenRouter upstream provider order (comma-separated).
# Empty = let OpenRouter pick freely (recommended for Qwen/DeepSeek/Mistral).
# Set to "Azure" when using OpenAI models from a CN IP — direct OpenAI is blocked.
OPENROUTER_PROVIDER_ORDER=""

# ---------- Provider fallbacks (only used if LLM_PROVIDER is switched) ----------

# DeepSeek direct API (CN-reachable, very cheap) — https://platform.deepseek.com
DEEPSEEK_API_KEY=""
DEEPSEEK_MAIN_MODEL="deepseek-chat"

# Qwen / DashScope direct (Alibaba Cloud native) — https://dashscope.aliyun.com
QWEN_API_KEY=""
QWEN_MAIN_MODEL="qwen-plus"

# Optional outbound HTTPS proxy. Leave empty to disable.
HTTPS_PROXY=""
