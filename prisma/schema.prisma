// AI 保研复试·科研经历深挖
// 三张表:Session(一次模拟面试) / Turn(一轮问答) / Report(最终反馈)

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Session {
  id         String   @id @default(cuid())
  // 用户粘贴或 AI 生成的科研经历原文
  experience String
  // 研究领域,供面试官调用专业语境(如 "计算机视觉" / "凝聚态物理")
  field      String
  // 目标院校层次 - 已从 UI 下线但 DB 列保留作 backward compat (always "top5")
  targetTier String   @default("top5")
  // 预期问答轮数: 短 5 / 中 10 / 长 15 - 用于动态调整面试节奏
  targetTurns Int     @default(10)
  createdAt  DateTime @default(now())
  turns      Turn[]
  report     Report?
}

model Turn {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  // 'interviewer' 由 LLM 产出, 'candidate' 由用户输入
  role      String
  content   String
  // 追问命中的维度: motivation / method / data / failure / reflection
  dimension String?
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
}

model Report {
  id         String   @id @default(cuid())
  sessionId  String   @unique
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  // 五维度评分 JSON: { motivation, method, data, failure, reflection } 0-10
  scoresJson String
  // markdown 反馈正文(优势/薄弱点/改进建议/示范答法)
  feedback   String
  createdAt  DateTime @default(now())
}

// 每次 LLM 调用的成本记录 - 用于实时监控花销
// 灵感来自评分说明:"track spend on every run"
model UsageLog {
  id               String   @id @default(cuid())
  // sample / session_open / chat / report
  endpoint         String
  // OpenRouter model id, e.g. "google/gemini-2.5-flash-lite"
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  // 按 lib/usage.ts 的 pricing table 估算的美元成本(乘以 1e6 存为整数微美元,
  // 避免 SQLite 浮点累加误差)
  costMicros       Int
  // 关联到具体会话(报销分析 / 显示给用户)。sample 等无 session 的调用为 null。
  sessionId        String?
  // 调用是否成功 - 失败的也要记录(可能仍消耗少量 token)
  ok               Boolean  @default(true)
  errorMessage     String?
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([endpoint, createdAt])
  @@index([sessionId])
}
